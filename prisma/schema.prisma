generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Prompt {
  id        String   @id @default(cuid())
  text      String
  method    String   @default("biomimicry")
  createdAt DateTime @default(now())

  @@map("prompts")
}
